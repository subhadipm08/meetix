# Server Configuration
PORT=8000
NODE_ENV=dev

# Database Configuration
MONGODB_URI=mongodb://username:password@localhost:27017/meetixdb?authSource=admin

# Redis Configuration
REDIS_URI=redis://localhost:6379

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# JWT Secrets (Generate secure random values in production)
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=10d

# Email Service Configuration (Nodemailer - Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Meetix <your_email@gmail.com>"
