# Meetix Client Environment Variables (Sample)
# Copy this file to .env and configure the variables as needed.

# The base URL of the backend API
VITE_API_BASE_URL=http://localhost:8000/api/v1

# The URL of the backend Socket.io server
VITE_SOCKET_URL=http://localhost:8000

# The GitHub profile URL displayed in the app
VITE_GITHUB_PROFILE=https://github.com/subhadipm08
